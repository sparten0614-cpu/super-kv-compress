+// ============================================================================
+// Per-layer KV type map: parse "0:q8_0,1-30:q4_0,31:q8_0" format
+// ============================================================================
+static std::map<int, ggml_type> g_kv_type_map;
+static bool g_kv_type_map_parsed = false;
+
+static ggml_type kv_type_from_name(const std::string & name) {
+    for (int t = 0; t < GGML_TYPE_COUNT; t++) {
+        if (ggml_type_name((ggml_type)t) && name == ggml_type_name((ggml_type)t)) {
+            return (ggml_type)t;
+        }
+    }
+    return GGML_TYPE_COUNT;  // invalid
+}
+
+static void parse_kv_type_map() {
+    if (g_kv_type_map_parsed) return;
+    g_kv_type_map_parsed = true;
+
+    const char * env = getenv("KV_TYPE_MAP");
+    if (!env || !env[0]) return;
+
+    std::string map_str(env);
+    std::istringstream ss(map_str);
+    std::string entry;
+
+    while (std::getline(ss, entry, ',')) {
+        // Parse "layer:type" or "start-end:type"
+        auto colon = entry.find(':');
+        if (colon == std::string::npos) continue;
+
+        std::string range = entry.substr(0, colon);
+        std::string type_name = entry.substr(colon + 1);
+        ggml_type type = kv_type_from_name(type_name);
+        if (type == GGML_TYPE_COUNT) {
+            LLAMA_LOG_WARN("%s: unknown type '%s' in KV_TYPE_MAP\n", __func__, type_name.c_str());
+            continue;
+        }
+
+        auto dash = range.find('-');
+        if (dash == std::string::npos) {
+            // Single layer
+            int layer = std::stoi(range);
+            g_kv_type_map[layer] = type;
+        } else {
+            // Range
+            int start = std::stoi(range.substr(0, dash));
+            int end   = std::stoi(range.substr(dash + 1));
+            for (int i = start; i <= end; i++) {
+                g_kv_type_map[i] = type;
+            }
+        }
+    }
+
+    if (!g_kv_type_map.empty()) {
+        LLAMA_LOG_INFO("%s: KV_TYPE_MAP: %zu layer overrides\n", __func__, g_kv_type_map.size());
+    }
+}
+
+static ggml_type get_layer_kv_type(int il, ggml_type default_type) {
+    parse_kv_type_map();
+    auto it = g_kv_type_map.find(il);
+    if (it != g_kv_type_map.end()) {
+        return it->second;
+    }
+    return default_type;
+}
