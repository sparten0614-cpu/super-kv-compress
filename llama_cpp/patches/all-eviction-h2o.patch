+// ============================================================================
+// Expected Attention: Training-free NIAH-safe eviction scoring
+// ============================================================================
+// SnapKV: One-shot eviction after prefill using accumulated attention scores
+// ============================================================================
+static bool g_snapkv_fired = false;
+
+// Expected Attention eviction: compute scores from K statistics, then evict
+static void expected_attn_evict(llama_memory_t mem, const common_params & params, int & n_past) {
+    if (!g_exp_attn.enabled || g_snapkv_fired || n_past <= 0) return;
+    g_snapkv_fired = true;
+
+    const int budget = std::max(1, (int)(n_past * (1.0f - params.evict_ratio)));
+    const int n_sink = std::min(params.evict_sink, budget / 2);
+    const int n_evict = n_past - budget;
+
+    if (n_evict <= 0) {
+        LOG_INF("ExpAttn: no eviction needed (n_past=%d <= budget=%d)\n", n_past, budget);
+        return;
+    }
+
+    LOG_INF("ExpAttn: scoring with Q stats (q_samples=%d) + K vectors (n_stored=%d), d=%d\n",
+            g_exp_attn.q_samples, (int)g_exp_attn.k_vecs.size(), g_exp_attn.d);
+
+    // Phase 2: Pure K-based scoring using stored K vectors + Gaussian query model
+    if (!g_exp_attn.k_vecs.empty() && (int)g_exp_attn.k_vecs.size() >= n_past) {
+        // Compute Expected Attention scores for all positions
+        auto ea_scores = g_exp_attn.compute_all_scores();
+
+        LOG_INF("ExpAttn: K-based scores computed, min=%.4f max=%.4f\n",
+                *std::min_element(ea_scores.begin(), ea_scores.begin() + n_past),
+                *std::max_element(ea_scores.begin(), ea_scores.begin() + n_past));
+
+        // Build (score, position) pairs for non-sink tokens, sort by score ascending
+        std::vector<std::pair<double, int>> scored;
+        for (int i = n_sink; i < n_past; i++) {
+            scored.push_back({ea_scores[i], i});
+        }
+        std::sort(scored.begin(), scored.end());
+
+        // Evict lowest-score tokens
+        int actual = std::min(n_evict, (int)scored.size());
+        std::vector<int> victims;
+        for (int i = 0; i < actual; i++) {
+            victims.push_back(scored[i].second);
+        }
+
+        // Remove back-to-front
+        std::sort(victims.rbegin(), victims.rend());
+        int remaining = n_past;
+        for (int pos : victims) {
+            llama_memory_seq_rm(mem, 0, pos, pos + 1);
+            llama_memory_seq_add(mem, 0, pos + 1, remaining, -1);
+            remaining--;
+        }
+        n_past = remaining;
+        LOG_INF("ExpAttn: evicted %d tokens (K-based), n_past=%d\n", actual, n_past);
+
+    } else if (g_h2o.enabled && g_h2o_callback_count > 0) {
+        // Fallback: use H2O attention scores
+        LOG_INF("ExpAttn: fallback to H2O scores (%d callbacks, %d k_vecs)\n",
+                g_h2o_callback_count, (int)g_exp_attn.k_vecs.size());
+        auto victims = g_h2o.batch_evict(n_past, n_sink, n_evict);
+        int remaining = n_past;
+        for (int i = (int)victims.size() - 1; i >= 0; i--) {
+            llama_memory_seq_rm(mem, 0, victims[i], victims[i] + 1);
+            llama_memory_seq_add(mem, 0, victims[i] + 1, remaining, -1);
+            remaining--;
+        }
+        n_past = remaining;
+        LOG_INF("ExpAttn: evicted %d tokens (H2O fallback), n_past=%d\n", (int)victims.size(), n_past);
+    } else {
+        LOG_WRN("ExpAttn: no scores available, falling back to StreamingLLM eviction\n");
+        // StreamingLLM fallback: evict middle tokens
+        const int evict_start = n_sink;
+        const int evict_end = evict_start + n_evict;
+        llama_memory_seq_rm(mem, 0, evict_start, evict_end);
+        llama_memory_seq_add(mem, 0, evict_end, n_past, -n_evict);
+        n_past -= n_evict;
+    }
+}
+
+static void snapkv_evict(llama_memory_t mem, const common_params & params, int & n_past) {
+    if (!g_h2o.enabled || g_snapkv_fired || n_past <= 0) return;
+    g_snapkv_fired = true;
+
+    const int budget = std::max(1, (int)(n_past * (1.0f - params.evict_ratio)));
+    const int n_sink = std::min(params.evict_sink, budget / 2);
+    const int n_evict = n_past - budget;
+
+    if (n_evict <= 0) {
+        LOG_INF("SnapKV: no eviction needed (n_past=%d <= budget=%d)\n", n_past, budget);
+        return;
+    }
+
+    LOG_INF("SnapKV: evicting %d tokens (keeping %d/%d, sink=%d, callbacks=%d)\n",
+            n_evict, budget, n_past, n_sink, g_h2o_callback_count);
+
+    // Use H2O accumulated scores for eviction
+    auto victims = g_h2o.batch_evict(n_past, n_sink, n_evict);
+
+    // Remove from KV cache back-to-front
+    int remaining = n_past;
+    for (int i = (int)victims.size() - 1; i >= 0; i--) {
+        llama_memory_seq_rm(mem, 0, victims[i], victims[i] + 1);
+        llama_memory_seq_add(mem, 0, victims[i] + 1, remaining, -1);
+        remaining--;
+    }
+    n_past = remaining;
+
+    LOG_INF("SnapKV: done, evicted %d tokens, n_past=%d\n", (int)victims.size(), n_past);
+}
