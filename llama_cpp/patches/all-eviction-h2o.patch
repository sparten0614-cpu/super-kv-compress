index 716a30f..4e8763b 100644
--- a/tools/completion/completion.cpp
+++ b/tools/completion/completion.cpp
@@ -32,6 +32,190 @@
 #pragma warning(disable: 4244 4267) // possible loss of data
 #endif
 
+// ============================================================================
+// H2O: Heavy-Hitter Oracle — Attention-aware KV cache eviction
+// ============================================================================
+struct h2o_state {
+    std::vector<double> scores;  // per-position cumulative attention score
+    int n_layers = 0;
+    int n_kv_max = 0;
+    int n_heads  = 0;            // total query heads
+    bool enabled = false;
+
+    void init(int layers, int kv_max, int heads) {
+        n_layers = layers;
+        n_kv_max = kv_max;
+        n_heads  = heads;
+        scores.assign(kv_max, 0.0);
+        enabled  = true;
+    }
+
+    // Accumulate attention scores from softmax output
+    // attn shape (ggml): [n_kv, n_tokens, n_head, 1] (after permute)
+    // We sum across the query dimension (n_tokens) for each KV position
+    void accumulate(const float * attn_data, int n_kv, int n_tokens, int n_head) {
+        if (!enabled || !attn_data) return;
+        // attn layout: attn[kv_pos * n_tokens * n_head + tok * n_head + head]
+        // Actually ggml stores row-major in ne[0] dimension:
+        // ne[0]=n_kv, ne[1]=n_tokens, ne[2]=n_head
+        // So attn[head][tok][kv] = attn_data[head * n_tokens * n_kv + tok * n_kv + kv]
+        for (int h = 0; h < n_head; h++) {
+            for (int t = 0; t < n_tokens; t++) {
+                const float * row = attn_data + (h * n_tokens + t) * n_kv;
+                for (int k = 0; k < n_kv && k < n_kv_max; k++) {
+                    scores[k] += (double)row[k];
+                }
+            }
+        }
+    }
+
+    // Find the token with lowest score to evict (excluding sink tokens)
+    // Returns the position to evict, or -1 if nothing to evict
+    int find_evict_target(int n_cached, int n_sink) const {
+        if (!enabled || n_cached <= n_sink) return -1;
+        int min_pos = -1;
+        double min_score = 1e30;
+        for (int i = n_sink; i < n_cached; i++) {
+            if (scores[i] < min_score) {
+                min_score = scores[i];
+                min_pos = i;
+            }
+        }
+        return min_pos;
+    }
+
+    // After evicting position `pos`, shift scores down
+    void on_evict(int pos, int n_cached) {
+        if (!enabled || pos < 0) return;
+        for (int i = pos; i < n_cached - 1; i++) {
+            scores[i] = scores[i + 1];
+        }
+        scores[n_cached - 1] = 0.0;
+    }
+
+    // Batch eviction: find and remove n_evict lowest-score tokens
+    // Returns positions evicted (sorted ascending) and updates scores array
+    // More efficient than repeated find+evict for large n_evict
+    std::vector<int> batch_evict(int n_cached, int n_sink, int n_evict) {
+        if (!enabled || n_evict <= 0) return {};
+
+        // Collect (score, position) for non-sink tokens
+        std::vector<std::pair<double, int>> scored;
+        scored.reserve(n_cached - n_sink);
+        for (int i = n_sink; i < n_cached; i++) {
+            scored.push_back({scores[i], i});
+        }
+
+        // Sort by score ascending
+        std::sort(scored.begin(), scored.end());
+
+        int actual = std::min(n_evict, (int)scored.size());
+        std::vector<int> victims;
+        victims.reserve(actual);
+        for (int i = 0; i < actual; i++) {
+            victims.push_back(scored[i].second);
+        }
+
+        // Remove back-to-front (preserves earlier indices)
+        std::sort(victims.rbegin(), victims.rend());
+        for (int pos : victims) {
+            on_evict(pos, n_cached);
+            n_cached--;
+        }
+
+        std::sort(victims.begin(), victims.end());
+        return victims;
+    }
+};
+
+static h2o_state g_h2o;
+static int g_h2o_callback_count = 0;  // debug: count callback invocations
+
+// Eval callback: intercepts tensors during graph execution
+static bool h2o_eval_callback(struct ggml_tensor * t, bool ask, void * user_data) {
+    (void)user_data;
+    if (!g_h2o.enabled) return true;
+
+    // We only care about the softmax output tensor
+    const char * name = ggml_get_name(t);
+    if (!name) return true;
+
+    // Match "kq_soft_max-N" where N is layer index
+    const bool is_attn = (strncmp(name, "kq_soft_max-", 12) == 0);
+
+    if (ask) return is_attn;  // only request data for attention tensors
+
+    if (!is_attn) return true;  // skip non-attention tensors
+
+    // Tensor is ready — read attention weights
+    // Shape: [n_kv, n_tokens, n_head, 1]
+    const int n_kv     = t->ne[0];
+    const int n_tokens = t->ne[1];
+    const int n_head   = t->ne[2];
+
+    // Debug: log first few callback invocations
+    g_h2o_callback_count++;
+    if (g_h2o_callback_count <= 5 || g_h2o_callback_count % 100 == 0) {
+        LOG_INF("H2O callback #%d: tensor=%s shape=[%d,%d,%d] type=%d\n",
+                g_h2o_callback_count, name, n_kv, n_tokens, n_head, (int)t->type);
+    }
+
+    // Read data (may need to copy from GPU)
+    const size_t data_size = ggml_nbytes(t);
+    std::vector<float> buf(data_size / sizeof(float));
+    ggml_backend_tensor_get(t, buf.data(), 0, data_size);
+
+    g_h2o.accumulate(buf.data(), n_kv, n_tokens, n_head);
+
+    return true;
+}
+
+// ============================================================================
+// SnapKV: One-shot eviction after prefill using accumulated attention scores
+// ============================================================================
+static bool g_snapkv_fired = false;
+
+static void snapkv_evict(llama_memory_t mem, const common_params & params, int & n_past) {
+    if (!g_h2o.enabled || g_snapkv_fired || n_past <= 0) return;
+    g_snapkv_fired = true;
+
+    const int budget = std::max(1, (int)(n_past * (1.0f - params.evict_ratio)));
+    const int n_sink = std::min(params.evict_sink, budget / 2);
+    const int n_evict = n_past - budget;
+
+    if (n_evict <= 0) {
+        LOG_INF("SnapKV: no eviction needed (n_past=%d <= budget=%d)\n", n_past, budget);
+        return;
+    }
+
+    // Print score stats before eviction
+    double min_s = 1e30, max_s = -1e30;
+    int nonzero = 0;
+    for (int i = 0; i < n_past; i++) {
+        if (g_h2o.scores[i] < min_s) min_s = g_h2o.scores[i];
+        if (g_h2o.scores[i] > max_s) max_s = g_h2o.scores[i];
+        if (g_h2o.scores[i] > 0) nonzero++;
+    }
+    LOG_INF("SnapKV: evicting %d tokens (keeping %d/%d, sink=%d, callbacks=%d, "
+            "scores: min=%.2f max=%.2f nonzero=%d/%d)\n",
+            n_evict, budget, n_past, n_sink, g_h2o_callback_count,
+            min_s, max_s, nonzero, n_past);
+
+    // Use H2O accumulated scores for eviction
+    auto victims = g_h2o.batch_evict(n_past, n_sink, n_evict);
+
+    // Remove from KV cache back-to-front
+    int remaining = n_past;
+    for (int i = (int)victims.size() - 1; i >= 0; i--) {
+        llama_memory_seq_rm(mem, 0, victims[i], victims[i] + 1);
+        llama_memory_seq_add(mem, 0, victims[i] + 1, remaining, -1);
+        remaining--;
+    }
+    n_past = remaining;
+
+    LOG_INF("SnapKV: done, evicted %d tokens, n_past=%d\n", (int)victims.size(), n_past);
+}
+
 static llama_context           ** g_ctx;
 static llama_model             ** g_model;
 static common_sampler          ** g_smpl;
@@ -94,6 +278,27 @@ int main(int argc, char ** argv) {
         return 1;
     }
 
