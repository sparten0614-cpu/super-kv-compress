+static expected_attn_state g_exp_attn;
+
+// Eval callback: intercepts tensors during graph execution
+static bool h2o_eval_callback(struct ggml_tensor * t, bool ask, void * user_data) {
+    (void)user_data;
+
+    const char * name = ggml_get_name(t);
+    if (!name) return true;
+
+    const bool is_attn = g_h2o.enabled && (strncmp(name, "kq_soft_max-", 12) == 0);
+    const bool is_kcur = g_exp_attn.enabled && (strncmp(name, "Kcur-", 5) == 0);
+    const bool is_qcur = g_exp_attn.enabled && (strncmp(name, "Qcur-", 5) == 0);
+
+    if (ask) return is_attn || is_kcur || is_qcur;
+
+    if (!is_attn && !is_kcur && !is_qcur) return true;
+
+    if (is_attn) {
+        // H2O: accumulate softmax attention scores
+        const int n_kv     = t->ne[0];
+        const int n_tokens = t->ne[1];
+        const int n_head   = t->ne[2];
+
+        g_h2o_callback_count++;
+        if (g_h2o_callback_count <= 3) {
+            LOG_INF("H2O callback #%d: %s [%d,%d,%d]\n",
+                    g_h2o_callback_count, name, n_kv, n_tokens, n_head);
+        }
+
+        const size_t data_size = ggml_nbytes(t);
+        std::vector<float> buf(data_size / sizeof(float));
+        ggml_backend_tensor_get(t, buf.data(), 0, data_size);
+        g_h2o.accumulate(buf.data(), n_kv, n_tokens, n_head);
+    }
+
+    // Helper lambda: read tensor to float buffer
+    auto read_to_float = [](const ggml_tensor * tensor, size_t n_elems) -> std::vector<float> {
+        std::vector<float> buf(n_elems);
+        if (tensor->type == GGML_TYPE_F32) {
+            ggml_backend_tensor_get(tensor, buf.data(), 0, n_elems * sizeof(float));
+        } else if (tensor->type == GGML_TYPE_F16) {
+            std::vector<uint16_t> buf16(n_elems);
+            ggml_backend_tensor_get(tensor, buf16.data(), 0, n_elems * sizeof(uint16_t));
+            for (size_t i = 0; i < n_elems; i++) {
+                buf[i] = ggml_fp16_to_fp32(buf16[i]);
+            }
+        } else {
+            buf.clear();  // unsupported
+        }
+        return buf;
+    };
+
+    if (is_kcur || is_qcur) {
+        // Parse layer index from tensor name: "Kcur-N" or "Qcur-N"
+        const int layer_idx = atoi(name + 5);
+
+        // Auto-detect number of layers on first pass, then lock to middle layer
+        // This prevents k_vecs from interleaving across layers, which would break
+        // the score-to-position mapping in expected_attn_evict()
+        if (!g_exp_attn_layer_detected) {
+            if (layer_idx <= g_exp_attn_max_layer_seen && g_exp_attn_max_layer_seen > 0) {
+                // Layer index wrapped around — first pass complete
+                int n_layers = g_exp_attn_max_layer_seen + 1;
+                g_exp_attn_target_layer = n_layers / 2;
+                g_exp_attn_layer_detected = true;
+                LOG_INF("ExpAttn: auto-detected %d layers, using layer %d for K/Q scoring\n",
+                        n_layers, g_exp_attn_target_layer);
+            }
+            g_exp_attn_max_layer_seen = std::max(g_exp_attn_max_layer_seen, layer_idx);
+            // Skip storing during auto-detection (first eval batch)
+            return true;
+        }
+
+        // Only collect from target layer — ensures k_vecs[i] == position i
+        if (layer_idx != g_exp_attn_target_layer) return true;
+    }
+
+    if (is_kcur) {
+        // Store K vectors for per-position scoring (single layer only)
+        // Kcur shape: [head_dim, n_head_kv, n_tokens]
+        const int head_dim = t->ne[0];
+        const int n_head_kv = t->ne[1];
+        const int n_tokens = t->ne[2];
+        const int n_embd_kv = head_dim * n_head_kv;
+
+        auto buf = read_to_float(t, head_dim * n_head_kv * n_tokens);
+        if (!buf.empty()) {
+            for (int ti = 0; ti < n_tokens; ti++) {
+                g_exp_attn.store_keys(buf.data() + ti * n_embd_kv, n_embd_kv, 1);
+            }
+        }
+    }
+
+    if (is_qcur) {
+        // Accumulate Q vector statistics (single layer only, matching K layer)
+        // Qcur shape: [head_dim, n_head, n_tokens]
+        const int head_dim = t->ne[0];
+        const int n_head_q = t->ne[1];
+        const int n_tokens = t->ne[2];
+
+        auto buf = read_to_float(t, head_dim * n_head_q * n_tokens);
+        if (!buf.empty()) {
+            const int n_embd_q = head_dim * n_head_q;
+            for (int ti = 0; ti < n_tokens; ti++) {
+                g_exp_attn.accumulate_queries(buf.data() + ti * n_embd_q, n_embd_q, 1);
+            }
+        }
+    }
+
+    return true;
+}
