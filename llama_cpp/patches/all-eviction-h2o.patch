+
+// Read K max abs values from KV cache (F16 type expected for calibration)
+void llama_kv_cache::read_k_max(float * k_max_out, int n_layer, int n_tokens) const {
+    LLAMA_LOG_INFO("[TQKV read_k_max] layers=%zu, n_layer=%d, n_tokens=%d\n",
+                   layers.size(), n_layer, n_tokens);
+    for (int il = 0; il < n_layer && il < (int)layers.size(); il++) {
+        ggml_tensor * k = layers[il].k;
+        if (!k) {
+            LLAMA_LOG_INFO("[TQKV read_k_max] layer %d: k is null\n", il);
+            k_max_out[il] = 0.0f;
+            continue;
+        }
+        if (k->type != GGML_TYPE_F16) {
+            LLAMA_LOG_INFO("[TQKV read_k_max] layer %d: type=%d (not F16=%d)\n", il, k->type, GGML_TYPE_F16);
+            k_max_out[il] = 0.0f;
+            continue;
+        }
+
+        const int64_t n_embd = k->ne[0];
+        const size_t row_bytes = n_embd * ggml_type_size(GGML_TYPE_F16);
+        std::vector<uint16_t> row_buf(n_embd);
+
+        float layer_max = 0.0f;
+        int rows_to_read = std::min((int64_t)n_tokens, k->ne[1]);
+        if (il == 0) {
+            LLAMA_LOG_INFO("[TQKV read_k_max] layer 0: ne[0]=%lld ne[1]=%lld type=%d rows=%d row_bytes=%zu data=%p buffer=%p\n",
+                           (long long)n_embd, (long long)k->ne[1], k->type, rows_to_read, row_bytes,
+                           (void*)k->data, (void*)k->buffer);
+        }
+        for (int t = 0; t < rows_to_read; t++) {
+            // Use direct memory access (Apple Silicon unified memory)
+            // ggml_backend_tensor_get might not sync Metal buffers correctly
+            memcpy(row_buf.data(), (const char *)k->data + t * row_bytes, row_bytes);
+            for (int64_t j = 0; j < n_embd; j++) {
+                float val = ggml_fp16_to_fp32(row_buf[j]);
+                float av = fabsf(val);
+                if (av > layer_max) layer_max = av;
+            }
+        }
+        if (il == 0) {
+            LLAMA_LOG_INFO("[TQKV read_k_max] layer 0: max=%.4f, first5: %.4f %.4f %.4f %.4f %.4f\n",
+                           layer_max,
+                           rows_to_read > 0 ? ggml_fp16_to_fp32(row_buf[0]) : 0.0f,
+                           n_embd > 1 ? ggml_fp16_to_fp32(row_buf[1]) : 0.0f,
+                           n_embd > 2 ? ggml_fp16_to_fp32(row_buf[2]) : 0.0f,
+                           n_embd > 3 ? ggml_fp16_to_fp32(row_buf[3]) : 0.0f,
+                           n_embd > 4 ? ggml_fp16_to_fp32(row_buf[4]) : 0.0f);
+        }
+        k_max_out[il] = layer_max;
+    }
+}
+
+// Free function wrapper for tqkv_read_k_max
+void tqkv_read_k_max(struct llama_context * ctx, float * k_max_out, int n_layer, int n_tokens) {
+    llama_memory_t mem = llama_get_memory(ctx);
+    auto * kv = dynamic_cast<llama_kv_cache *>(mem);
+    if (kv) {
+        kv->read_k_max(k_max_out, n_layer, n_tokens);
+    }
+}
