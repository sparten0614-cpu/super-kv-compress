index 716a30f..64921b3 100644
--- a/tools/completion/completion.cpp
+++ b/tools/completion/completion.cpp
@@ -32,6 +32,402 @@
 #pragma warning(disable: 4244 4267) // possible loss of data
 #endif
 
+// ============================================================================
+// H2O: Heavy-Hitter Oracle — Attention-aware KV cache eviction
+// ============================================================================
+struct h2o_state {
+    std::vector<double> scores;  // per-position cumulative attention score
+    int n_layers = 0;
+    int n_kv_max = 0;
+    int n_heads  = 0;            // total query heads
+    bool enabled = false;
+
+    void init(int layers, int kv_max, int heads) {
+        n_layers = layers;
+        n_kv_max = kv_max;
+        n_heads  = heads;
+        scores.assign(kv_max, 0.0);
+        enabled  = true;
+    }
+
+    // Accumulate attention scores from softmax output
+    // attn shape (ggml): [n_kv, n_tokens, n_head, 1] (after permute)
+    // We sum across the query dimension (n_tokens) for each KV position
+    void accumulate(const float * attn_data, int n_kv, int n_tokens, int n_head) {
+        if (!enabled || !attn_data) return;
+        // attn layout: attn[kv_pos * n_tokens * n_head + tok * n_head + head]
+        // Actually ggml stores row-major in ne[0] dimension:
+        // ne[0]=n_kv, ne[1]=n_tokens, ne[2]=n_head
+        // So attn[head][tok][kv] = attn_data[head * n_tokens * n_kv + tok * n_kv + kv]
+        for (int h = 0; h < n_head; h++) {
+            for (int t = 0; t < n_tokens; t++) {
+                const float * row = attn_data + (h * n_tokens + t) * n_kv;
+                for (int k = 0; k < n_kv && k < n_kv_max; k++) {
+                    scores[k] += (double)row[k];
+                }
+            }
+        }
+    }
+
+    // Find the token with lowest score to evict (excluding sink tokens)
+    // Returns the position to evict, or -1 if nothing to evict
+    int find_evict_target(int n_cached, int n_sink) const {
+        if (!enabled || n_cached <= n_sink) return -1;
+        int min_pos = -1;
+        double min_score = 1e30;
+        for (int i = n_sink; i < n_cached; i++) {
+            if (scores[i] < min_score) {
+                min_score = scores[i];
+                min_pos = i;
+            }
+        }
+        return min_pos;
+    }
+
+    // After evicting position `pos`, shift scores down
+    void on_evict(int pos, int n_cached) {
+        if (!enabled || pos < 0) return;
+        for (int i = pos; i < n_cached - 1; i++) {
+            scores[i] = scores[i + 1];
+        }
+        scores[n_cached - 1] = 0.0;
+    }
+
+    // Batch eviction: find and remove n_evict lowest-score tokens
+    // Returns positions evicted (sorted ascending) and updates scores array
+    // More efficient than repeated find+evict for large n_evict
+    std::vector<int> batch_evict(int n_cached, int n_sink, int n_evict) {
+        if (!enabled || n_evict <= 0) return {};
+
+        // Collect (score, position) for non-sink tokens
+        std::vector<std::pair<double, int>> scored;
+        scored.reserve(n_cached - n_sink);
+        for (int i = n_sink; i < n_cached; i++) {
+            scored.push_back({scores[i], i});
+        }
+
+        // Sort by score ascending
+        std::sort(scored.begin(), scored.end());
+
+        int actual = std::min(n_evict, (int)scored.size());
+        std::vector<int> victims;
+        victims.reserve(actual);
+        for (int i = 0; i < actual; i++) {
+            victims.push_back(scored[i].second);
+        }
+
+        // Remove back-to-front (preserves earlier indices)
+        std::sort(victims.rbegin(), victims.rend());
+        for (int pos : victims) {
+            on_evict(pos, n_cached);
+            n_cached--;
+        }
+
+        std::sort(victims.begin(), victims.end());
+        return victims;
+    }
+};
+
+static h2o_state g_h2o;
+static int g_h2o_callback_count = 0;
+
+// Layer filtering for Expected Attention: only collect K/Q from one layer
+// to avoid interleaving k_vecs across layers (which breaks score-to-position mapping)
+static int g_exp_attn_target_layer = -1;    // -1 = auto-detecting
+static int g_exp_attn_max_layer_seen = -1;
+static bool g_exp_attn_layer_detected = false;
+
+// Expected Attention state — declared here so callback can reference it
+struct expected_attn_state {
+    // Q statistics: μ_Q and Σ_Q (from query vectors, NOT key vectors)
+    std::vector<double> q_sum;       // [d] running sum of Q vectors for mean
+    std::vector<double> q_sq_sum;    // [d] running sum of Q^2 for variance
+    int q_samples = 0;               // number of Q vectors accumulated
+
+    // Stored K vectors for per-position scoring
+    std::vector<std::vector<float>> k_vecs;  // [n_positions][d]
+
+    int d = 0;                       // head dimension
+    int n_kv_max = 0;
+    bool enabled = false;
+
+    void init(int head_dim, int kv_max) {
+        d = head_dim;
+        n_kv_max = kv_max;
+        q_sum.assign(d, 0.0);
+        q_sq_sum.assign(d, 0.0);
+        q_samples = 0;
+        k_vecs.clear();
+        k_vecs.reserve(kv_max);
+        enabled = true;
+    }
+
+    // Accumulate Q vector statistics (from Qcur tensors)
+    void accumulate_queries(const float * q_data, int n_embd, int n_tokens) {
+        if (!enabled || !q_data) return;
+        int dim = std::min(n_embd, d);
+        for (int t = 0; t < n_tokens; t++) {
+            const float * qv = q_data + t * n_embd;
+            for (int j = 0; j < dim; j++) {
+                q_sum[j]    += qv[j];
+                q_sq_sum[j] += (double)qv[j] * qv[j];
+            }
+            q_samples++;
+        }
+    }
+
+    // Store K vectors (from Kcur tensors) for later per-position scoring
+    void store_keys(const float * k_data, int n_embd, int n_tokens) {
+        if (!enabled || !k_data) return;
+        int dim = std::min(n_embd, d);
+        for (int t = 0; t < n_tokens; t++) {
+            if ((int)k_vecs.size() < n_kv_max) {
+                k_vecs.emplace_back(k_data + t * n_embd, k_data + t * n_embd + dim);
+            }
+        }
+    }
+
+    // Compute Expected Attention scores using Q statistics + stored K vectors
+    // Formula: z_i = exp(μ_Q^T k_i / √d + k_i^T diag(Σ_Q) k_i / 2d)
+    // Returns log-scores (higher = more important)
+    std::vector<double> compute_all_scores() const {
+        std::vector<double> scores(k_vecs.size(), 0.0);
+        if (!enabled || q_samples < 2 || d == 0 || k_vecs.empty()) return scores;
+
+        const double inv_n = 1.0 / q_samples;
+        const double inv_sqrt_d = 1.0 / sqrt((double)d);
+
+        // Pre-compute μ_Q and Σ_Q (diagonal) from Q statistics
+        std::vector<double> mu_q(d), var_q(d);
+        for (int j = 0; j < d; j++) {
+            mu_q[j]  = q_sum[j] * inv_n;
+            var_q[j] = q_sq_sum[j] * inv_n - mu_q[j] * mu_q[j];
+            if (var_q[j] < 1e-10) var_q[j] = 1e-10;
+        }
+
+        // Score each K position using Q statistics
+        // z_i = μ_Q^T k_i / √d + k_i^T diag(Σ_Q) k_i / (2d)
+        for (size_t i = 0; i < k_vecs.size(); i++) {
+            double dot_mu_k = 0.0;   // μ_Q^T k_i
+            double k_var_k = 0.0;    // k_i^T Σ_Q k_i
+            const auto & ki = k_vecs[i];
+            int dim = std::min((int)ki.size(), d);
+            for (int j = 0; j < dim; j++) {
+                dot_mu_k += mu_q[j] * ki[j];
+                k_var_k  += var_q[j] * ki[j] * ki[j];
+            }
+            scores[i] = dot_mu_k * inv_sqrt_d + k_var_k / (2.0 * d);
+        }
+
+        return scores;
+    }
+
+};
